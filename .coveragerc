[run]
source = nsclc_survival
omit =
    */nsclc_survival/__init__.py
    */nsclc_survival/__version__.py
    */nsclc_survival/__main__.py
    */nsclc_survival/utils.py
    tests/*    

[report]
show_missing = True
exclude_lines =
    pragma: no cover
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.: